<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Server is currently unavailable</title>
</head>
<body>
  <div class="main">
    <span class="maintitle">NetBreaker</span>

    <span class="errorno"><%= errno %></span>
    <span class="errormsg"><%= msg %></span>
  </div>



  <style>
    *{
      margin: 0px;
      padding: 0px;
      box-sizing: border-box;
    }
    .main{
      position: fixed;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      top: 0px;
      left: 0px;
      background-color: #161616;
      width: 100%;
      height: 100vh;
    }
    .errorno{
      font-family: sans-serif;
      font-size: 90px;
      color: #6b2525;
    }
    .errormsg{
      font-family: sans-serif;
      font-size: 20px;
      color: #6b2525;
    }
    .maintitle{
      font-size: 110px;
      color: #fff;
      margin-bottom: 40px;
    }
  </style>
</body>
</html>